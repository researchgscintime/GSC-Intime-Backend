# Server Configuration
PORT=5001

# Database Configuration
MONGO_URI=mongodb://127.0.0.1:27017/gsc-intime

# Admin Authentication
ADMIN_KEY=your-secure-admin-key-here

# Cloudflare R2 Configuration (S3-compatible storage)
# Get these from Cloudflare Dashboard > R2 > API Token
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://your-custom-domain.com
# OR use: R2_PUBLIC_URL=https://your-bucket-name.your-account-id.r2.cloudflarestorage.com

# Frontend API URL (for CORS configuration)
VITE_API_URL=http://localhost:5000/api
